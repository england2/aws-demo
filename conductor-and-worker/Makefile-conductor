SHELL := /usr/bin/env bash

GO ?= /home/t/.go/bin/go

ROOT := $(abspath $(dir $(lastword $(MAKEFILE_LIST))))
CONDUCTOR_DIR := $(ROOT)/conductor/go-conductor
PROTO_SCRIPT := $(ROOT)/../scripts_condtesting/gen-proto

OUT_DIR ?= $(HOME)/bin
CONDUCTOR_BIN ?= $(OUT_DIR)/conductor

.PHONY: build
build: $(CONDUCTOR_BIN)

.PHONY: FORCE
FORCE:

$(CONDUCTOR_BIN): FORCE
	@mkdir -p "$(OUT_DIR)"
	cd "$(CONDUCTOR_DIR)" && "$(GO)" build -o "$(CONDUCTOR_BIN)" .
	@printf 'built %s\n' "$(CONDUCTOR_BIN)"

.PHONY: test
test:
	cd "$(CONDUCTOR_DIR)" && "$(GO)" test ./...

.PHONY: proto
proto:
	"$(PROTO_SCRIPT)"

.PHONY: clean
clean:
	rm -f "$(CONDUCTOR_BIN)"
