#!/usr/bin/env fish
source (dirname (realpath (status filename)))/helpers.fish
set proto_dir "$repo_root/src/proto"

if not command -q protoc
    echo "error: protoc is missing or not on PATH" >&2
    exit 1
end

if not command -q protoc-gen-go
    echo "error: protoc-gen-go is missing or not on PATH" >&2
    exit 1
end

if not command -q protoc-gen-go-grpc
    echo "error: protoc-gen-go-grpc is missing or not on PATH" >&2
    exit 1
end

protoc \
    --proto_path="$proto_dir" \
    --go_out="$proto_dir" \
    --go_opt=paths=source_relative \
    --go-grpc_out="$proto_dir" \
    --go-grpc_opt=paths=source_relative \
    "$proto_dir/sharedproto.proto"
