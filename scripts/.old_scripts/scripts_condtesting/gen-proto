#!/usr/bin/env fish
source (dirname (realpath (status filename)))/helpers.fish
set proto_dir "$repo_root/conductor-and-worker/proto"

function require_commands
    for cmd in $argv
        if not command -q $cmd
            echo "error: $cmd is missing or not on PATH" >&2 ; exit 1
        end
    end
end

require_commands protoc protoc-gen-go protoc-gen-go-grpc

protoc \
    --proto_path="$proto_dir" \
    --go_out="$proto_dir" \
    --go_opt=paths=source_relative \
    --go-grpc_out="$proto_dir" \
    --go-grpc_opt=paths=source_relative \
    "$proto_dir/sharedproto.proto"
